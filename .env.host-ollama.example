# ============================================================================
# Variante : Ollama tourne NATIVEMENT sur l'hote (hors Docker), le backend
# du compose s'y connecte. Utile pour profiter d'un GPU non accessible depuis
# Docker (ex. carte AMD sous Windows).
#
# Utilisation :  cp .env.host-ollama.example .env   puis lancer SANS les
# services ollama du compose (voir "IMPORTANT" plus bas).
# ============================================================================

# --- MinIO (stockage objet) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents

# --- ChromaDB (base vectorielle) ---
CHROMA_COLLECTION=rag_documents

# --- Ollama (LLM local, execute sur l'hote) ---
OLLAMA_MODEL=qwen2.5:0.5b
# Le backend (dans un container) joint l'Ollama de l'hote via host.docker.internal.
#   - Docker Desktop (Windows / macOS) : fonctionne tel quel.
#   - Docker natif sous Linux : ajouter dans docker-compose.yml, service backend :
#         extra_hosts:
#           - "host.docker.internal:host-gateway"
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Parametres RAG ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# ============================================================================
# IMPORTANT - a faire cote hote / au lancement :
#
# 1. Installer et lancer Ollama nativement, puis telecharger le modele :
#        ollama pull qwen2.5:0.5b
#
# 2. Ollama doit ECOUTER SUR 0.0.0.0 (par defaut il n'ecoute que 127.0.0.1,
#    donc injoignable depuis un container). Definir la variable d'env de l'hote :
#        Windows (PowerShell, session courante) :  $env:OLLAMA_HOST = "0.0.0.0"
#        Windows (permanent) : setx OLLAMA_HOST "0.0.0.0"  (puis relancer Ollama)
#        Linux / macOS       :  export OLLAMA_HOST=0.0.0.0
#
# 3. Lancer le compose avec l'override dedie (n'active pas ollama embarque) :
#        docker compose -f docker-compose.yml -f docker-compose.host-ollama.yml up --build
# ============================================================================
