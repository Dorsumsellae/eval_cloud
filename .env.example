# Copiez ce fichier en .env et ajustez si besoin :  cp .env.example .env

# --- MinIO (stockage objet) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents

# --- ChromaDB (base vectorielle) ---
CHROMA_COLLECTION=rag_documents

# --- Ollama (LLM local) ---
OLLAMA_MODEL=qwen2.5:0.5b
# URL du serveur Ollama vu par le backend.
#   - Ollama dans docker compose (defaut) : http://ollama:11434
#   - Ollama natif sur l'hote (ex. GPU AMD sous Windows) : http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Parametres RAG ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# Workspace utilise quand aucun n'est precise (cloisonnement logique des documents).
DEFAULT_WORKSPACE=default

# --- Base de donnees applicative (notebooks, conversations, notes) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# URL vue par le backend (nom de service Docker `postgres`). En natif : localhost.
DATABASE_URL=postgresql+psycopg2://rag:rag@postgres:5432/rag

# --- Frontend Next.js ---
# URL du backend appelee depuis le NAVIGATEUR (pas le reseau Docker interne).
# Inlinee au build du frontend (prefixe NEXT_PUBLIC_) : pointe vers le port publie
# du backend. En local comme en Docker (ports publies) : http://localhost:8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Service ASR (transcription des videos sans sous-titres) ---
# Desactive par defaut. Pour l'activer :
#   1) decommenter ASR_SERVICE_URL ci-dessous ;
#   2) lancer avec le profil dedie : docker compose --profile asr up --build
# ASR_SERVICE_URL=http://asr:8100
# ASR_MODEL=small            # tiny/base/small/medium/large-v3 (compromis vitesse/qualite)
# ASR_DEVICE=cpu             # cpu ou cuda (si GPU disponible dans le conteneur asr)
# ASR_COMPUTE_TYPE=int8      # int8 (CPU) ou float16 (GPU)
# Jeton Hugging Face pour la DIARISATION (locuteurs) via pyannote (modele gated).
# Sans jeton, la transcription fonctionne mais sans separation des locuteurs.
# Prerequis : accepter les conditions de pyannote/speaker-diarization-3.1 sur huggingface.co
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
